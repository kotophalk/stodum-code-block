{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "stodum/code-block",
    "version": "1.0.7",
    "title": "StoDum Code Block",
    "category": "formatting",
    "icon": "editor-code",
    "description": "Syntax highlighted code block with auto language detection, clipboard copy, and dark/light mode toggle.",
    "keywords": [ "code", "syntax", "highlight", "developer", "programming" ],
    "supports": {
        "html": false,
        "multiple": true,
        "className": true,
        "align": [ "wide", "full" ]
    },
    "attributes": {
        "content": {
            "type": "string",
            "default": ""
        },
        "language": {
            "type": "string",
            "default": ""
        },
        "title": {
            "type": "string",
            "default": ""
        },
        "theme": {
            "type": "string",
            "default": ""
        }
    },
    "textdomain": "stodum-code-block",
    "editorStyle": "stodum-code-block-editor",
    "style": "stodum-code-block-frontend",
    "viewScript": "stodum-code-block-frontend"
}
